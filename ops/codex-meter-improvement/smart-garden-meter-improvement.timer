[Unit]
Description=Run meter OCR engineering agent daily

[Timer]
# Run in the daily Codex maintenance window. The home-net-watch UI audit omits
# 01:22 and the direct OCR batch omits 01:50 so this longer improvement loop
# does not create predictable global-lock no-op runs.
OnCalendar=*-*-* 01:22:30
Persistent=true
AccuracySec=10s
Unit=smart-garden-meter-improvement.service

[Install]
WantedBy=timers.target
